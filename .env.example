# Anthropic
ANTHROPIC_API_KEY=
# Optional: point at an Anthropic-compatible gateway (default https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# GitLab (self-hosted)
GITLAB_URL=https://gitlab.yourdomain.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
GITLAB_DEFAULT_BRANCH=main
GITLAB_MR_TARGET_BRANCH=main
GITLAB_MR_ASSIGNEE_ID=

# OpenSearch
OPENSEARCH_URL=https://opensearch.yourdomain.com
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=logs-*
OPENSEARCH_POLL_INTERVAL_SECONDS=60
OPENSEARCH_LOOKBACK_SECONDS=120

# Redis (for Asynq)
REDIS_URL=redis://localhost:6379

# App
PORT=3000
HUMAN_APPROVAL_REQUIRED=true
LOG_LEVEL=info
